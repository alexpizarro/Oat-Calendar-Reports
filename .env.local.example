# ============================================================
# Azure SQL Server Connection
# Format: sqlserver://<server>.database.windows.net:1433;database=<db>;user=<user>;password=<pass>;encrypt=true
# ============================================================
DATABASE_URL="sqlserver://your-server.database.windows.net:1433;database=hlanalytics;user=sqladmin;password=YourPassword;encrypt=true"

# ============================================================
# App Admin Authentication
# Generate password hash: node -e "const bcrypt = require('bcryptjs'); bcrypt.hash('yourpassword', 12).then(console.log)"
# IMPORTANT: In Next.js .env files, every "$" in the hash MUST be escaped as "\ 
# Example: $2a$12$abc... → \a\\...
# IMPORTANT: In Next.js env files, escape each "$" in bcrypt hashes as "\$".
# ============================================================
ADMIN_USERNAME="admin"
ADMIN_PASSWORD_HASH="\$2b\$12\$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ============================================================
# JWT Session Secret (64 hex chars = 32 bytes)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================================
JWT_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ============================================================
# Internal API Secret — used by Azure Timer Function to call /api/internal/run-jobs
# Generate: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
# ============================================================
INTERNAL_API_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ============================================================
# Encryption Key — AES-256-GCM key for GHL tokens at rest (64 hex chars = 32 bytes)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================================
ENCRYPTION_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ============================================================
# GoHighLevel Auth Mode
# "oauth"   — Use OAuth2 flow (recommended for production). Requires CLIENT_ID, CLIENT_SECRET, REDIRECT_URI.
# "private" — Use Private Integration Token per location. CLIENT_ID/SECRET not required.
# ============================================================
GHL_AUTH_MODE="oauth"

# OAuth credentials (only required when GHL_AUTH_MODE=oauth)
GHL_CLIENT_ID="your-ghl-client-id"
GHL_CLIENT_SECRET="your-ghl-client-secret"
GHL_REDIRECT_URI="https://your-app.azurestaticapps.net/api/oauth/callback"

# ============================================================
# Public base URL — used by timer function and OAuth redirects
# Local dev: http://localhost:3000
# Production: https://your-app.azurestaticapps.net
# ============================================================
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
